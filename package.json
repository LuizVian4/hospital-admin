{
  "name": "escala-hospital",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "docker compose up --build",
    "start:db": "docker compose up -d db",
    "stop": "docker compose down",
    "seed": "docker compose exec backend npm run db:seed -w @escala/backend",
    "dev": "npm run dev -w @escala/backend -w @escala/frontend",
    "dev:backend": "npm run dev -w @escala/backend",
    "dev:frontend": "npm run dev -w @escala/frontend",
    "db:migrate": "npm run db:migrate -w @escala/backend",
    "db:seed": "npm run db:seed -w @escala/backend",
    "build": "npm run build -w @escala/shared && npm run build -w @escala/backend && npm run build -w @escala/frontend"
  }
}
