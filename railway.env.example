# Variáveis para o serviço Backend no Railway (aba Variables).
# DATABASE_URL: use referência ao Postgres do mesmo projeto — não cole a URL manualmente.
DATABASE_URL=${{Postgres.DATABASE_URL}}

NODE_ENV=production
PORT=3001

# Gere um segredo forte (ex.: openssl rand -base64 48)
JWT_SECRET=altere-este-segredo-em-producao
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URL pública do frontend (vírgula para múltiplas origens)
CORS_ORIGINS=https://seu-frontend.up.railway.app

# Opcional: forçar SSL na conexão Postgres (automático para URLs *.rlwy.net)
# DATABASE_SSL=require
