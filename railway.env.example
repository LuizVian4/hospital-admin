# =============================================================================
# Backend (serviço API) — railway.toml na raiz
# =============================================================================
# DATABASE_URL: referência ao Postgres do mesmo projeto
DATABASE_URL=${{Postgres.DATABASE_URL}}

NODE_ENV=production

# Gere um segredo forte (ex.: openssl rand -base64 48)
JWT_SECRET=altere-este-segredo-em-producao
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Origem do frontend (vírgula para múltiplas)
# Domínios *.escala360.app e *.escala360.com.br são aceitos automaticamente.
CORS_ORIGINS=https://hospital-admin-frontend-production.up.railway.app,https://app.escala360.app

# Com domínios customizados api/app.escala360.app (opcional):
# COOKIE_DOMAIN=.escala360.app

# Opcional: forçar SSL na conexão Postgres (automático para URLs *.rlwy.net)
# DATABASE_SSL=require

# =============================================================================
# Frontend (segundo serviço) — railway.frontend.toml
# Settings → Config-as-code → railway.frontend.toml
# =============================================================================
# URL pública da API (usada no BUILD do Vite — obrigatória)
VITE_API_URL=https://hospital-admin-production.up.railway.app

# Ou, com domínio customizado:
# VITE_API_URL=https://api.escala360.app
