# Local (Docker Compose): postgres://postgres:postgres@localhost:5433/escala_hospital
# Railway (máquina local): use DATABASE_PUBLIC_URL do painel (host *.rlwy.net)
# Railway (serviço no mesmo projeto): ${{Postgres.DATABASE_URL}} — host postgres.railway.internal
DATABASE_URL=postgres://postgres:postgres@localhost:5433/escala_hospital
PORT=3001
VITE_API_URL=http://localhost:3001

# Autenticação (obrigatório em produção)
JWT_SECRET=altere-este-segredo-em-producao
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173

# Usuário admin inicial (usado pelo db:seed)
ADMIN_EMAIL=admin@hospital.local
ADMIN_PASSWORD=admin123
